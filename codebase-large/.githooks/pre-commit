#!/bin/sh
# Wiki pre-commit gate: lint errors are uncommittable.
# Install once per clone: git config core.hooksPath .githooks
cd "$(git rev-parse --show-toplevel)" || exit 1
python3 lint.py check
status=$?
if [ $status -ne 0 ]; then
    echo ""
    echo "pre-commit: lint errors block the commit. Fix them; do not bypass with --no-verify."
fi
exit $status
